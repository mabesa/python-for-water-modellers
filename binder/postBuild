#!/bin/bash
set -euxo pipefail

# Install the local package after repo2docker has installed the pinned
# third-party dependencies from binder/requirements.txt.
python -m pip install --no-deps -e .

# Confirm the resolved environment is internally consistent.
python -m pip check

# Fail the Binder build early if the tutorial runtime is incomplete.
python -c "import matplotlib, numpy, pandas, pygeohydro; from python_for_water_modellers import get_data_path; print(f'Binder data path: {get_data_path()}')"
